{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$HOME/**",
          "app": true
        }
      ]
    },
    "dialog:default",
    "fs:default",
    "fs:allow-read",
    "fs:read-all"
  ]
}
